+// ---------------------------------------------------------------------------
+// parseHtmlDocument — synchronous HTML parse (DOM-only mode)
+// ---------------------------------------------------------------------------
+// Parses HTML bytes into this Frame's document without executing scripts.
+// Used by Browser.parseStatic().
+
+pub fn parseHtmlDocument(self: *Frame, html: []const u8) !void {
+    const previous_parse_mode = self._parse_mode;
+    self._parse_mode = .document;
+    defer self._parse_mode = previous_parse_mode;
+
+    var parser = Parser.init(self.call_arena, self.document.asNode(), self);
+    parser.parse(html);
+
+    if (parser.err) |err_val| return err_val.err;
+    self.document._ready_state = .complete;
+}
