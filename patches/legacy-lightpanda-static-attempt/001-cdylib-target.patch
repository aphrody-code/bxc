+// ---------------------------------------------------------------------------
+// parseStatic — synchronous DOM-only parse (no_v8 mode)
+// ---------------------------------------------------------------------------
+// Creates a Session + Page, parses the HTML synchronously (no scripts), and
+// returns the root Frame.  The Frame is owned by the Browser/Session and is
+// freed when the Browser is deinitialized.
+
+const Parser = @import("parser/Parser.zig");
+const Frame  = @import("Frame.zig");
+const Node   = @import("webapi/Node.zig");
+const Notification = @import("../Notification.zig");
+
+pub fn parseStatic(self: *Browser, html: []const u8) !*Frame {
+    const notification = try Notification.init(self.app.allocator);
+    defer notification.deinit();
+
+    var session = try self.newSession(notification);
+    const frame = try session.createPage();
+    try frame.parseHtmlDocument(html);
+    return frame;
+}
