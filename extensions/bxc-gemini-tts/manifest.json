{
  "manifest_version": 3,
  "name": "bxc Gemini TTS",
  "version": "1.1.0",
  "description": "Lit a voix haute les reponses de Gemini (voix francaises) et synchronise la session Google en JSON vers bxc et le VPS.",
  "permissions": ["storage", "cookies", "alarms", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.google.com/*",
    "http://127.0.0.1:8765/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "bxc Gemini TTS",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content/gemini-tts.js"],
      "css": ["content/gemini-tts.css"],
      "run_at": "document_idle"
    }
  ]
}
