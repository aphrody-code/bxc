{
  "name": "api",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bunx tsc --noEmit",
    "typecheck": "bunx tsc --noEmit",
    "generate:types": "openapi-typescript http://localhost:3000/swagger/json -o src/types.ts",
    "db:push": "drizzle-kit push"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "openapi-typescript": "^7.13.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@bogeychan/elysia-logger": "^0.1.10",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "@libsql/client": "^0.17.3",
    "class-validator": "^0.15.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "graphql": "^16.14.0",
    "graphql-yoga": "^5.21.0",
    "reflect-metadata": "^0.2.2",
    "type-graphql": "^2.0.0-rc.3"
  }
}
