{
	"name": "bunlight-gemini",
	"version": "1.0.0",
	"description": "Bunlight native extension for Gemini CLI with auto-detect, subagent scraping, vision API, and SQLite memory.",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "bun build ./server.ts --compile --target=bun-linux-x64 --outfile bunlight-mcp",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint .",
		"test": "bun test"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "workspace:*",
		"@modelcontextprotocol/core": "workspace:*",
		"@modelcontextprotocol/server": "workspace:*",
		"@modelcontextprotocol/client": "workspace:*",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"oxlint": "latest"
	}
}
