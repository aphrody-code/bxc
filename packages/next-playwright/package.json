{
  "name": "@aphrody-code/next-playwright",
  "version": "0.1.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "description": "Next.js instant() navigation-testing primitive (port of @next/playwright) for bxc's CDP-backed test runner. Drives the next-instant-navigation-testing cookie protocol over Network.setCookies/getCookies/deleteCookies — no @playwright/test runtime dependency.",
  "keywords": [
    "aphrody",
    "bxc",
    "bun",
    "next",
    "nextjs",
    "playwright",
    "instant",
    "navigation-testing",
    "cache-components",
    "cdp"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "test": "bun test test/"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@aphrody-code/bxc-test": "*"
  },
  "peerDependenciesMeta": {
    "@aphrody-code/bxc-test": {
      "optional": true
    }
  }
}
