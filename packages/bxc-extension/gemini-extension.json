{
  "name": "bxc-gemini",
  "version": "1.0.0",
  "mcpServers": {
    "bxc-mcp": {
      "command": "bun",
      "args": ["run", "${extensionPath}${/}server.ts"],
      "cwd": "${extensionPath}",
      "trust": true
    }
  },
  "commands": [
    "commands/*.toml"
  ],
  "settings": [
    {
      "name": "SQLite Memory Path",
      "description": "Path to the SQLite database used for memory tuning.",
      "envVar": "BXC_MEMORY_DB",
      "sensitive": false
    }
  ]
}