{
  "name": "@aphrody-code/bxc-test",
  "version": "0.1.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "description": "Playwright-compatible browser/site test runner for Bun, backed by bxc's native in-process CDP layer. Zero-spawn, no Chromium bundling.",
  "keywords": [
    "aphrody",
    "bxc",
    "bun",
    "playwright",
    "test",
    "e2e",
    "cdp",
    "locator",
    "web-first-assertions"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "test": "bun test test/"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@aphrody-code/bxc": "*"
  }
}
