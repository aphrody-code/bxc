{
  "name": "@aphrody/x",
  "version": "1.0.7",
  "publishConfig": {
    "access": "public"
  },
  "description": "Headless X (Twitter) client in pure TypeScript for Bun. Cookie GraphQL + REST, bxc-aligned catalog sync and surface recon.",
  "keywords": [
    "aphrody",
    "bun",
    "x",
    "twitter",
    "client",
    "graphql",
    "headless",
    "bxc"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "test": "bun test",
    "catalog:sync": "bun ../../scripts/sync-x-catalog.ts",
    "coverage": "bun ../../scripts/x-coverage.ts",
    "recon": "bun ../../scripts/x-premium-recon.ts --profile max"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}