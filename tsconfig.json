{
	"compilerOptions": {
		"lib": ["ESNext", "DOM"],
		"target": "ESNext",
		"module": "ESNext",
		"moduleDetection": "force",
		"jsx": "preserve",
		"allowJs": false,

		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"paths": {
			"@aphrody/bxc": ["./src/api/browser.ts"],
			"@aphrody/bxc/scrapers/challonge": ["./packages/challonge/src/index.ts"],
			"@aphrody/bxc/scrapers/voiranime": ["./packages/voiranime/src/index.ts"],
			"@aphrody/bxc/scrapers/xcom": ["./packages/xcom/src/index.ts"],
			"@aphrody/bxc/scrapers/worldbeyblade": ["./packages/worldbeyblade/src/index.ts"],
			"@aphrody/bxc/scrapers/fut": ["./packages/fut/src/index.ts"],
			"@aphrody/bxc/scrapers/zukan": ["./packages/zukan/src/index.ts"],
			"@aphrody/bxc/*": ["./src/*"]
		},
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,

		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noPropertyAccessFromIndexSignature": false,

		"incremental": true,
		"tsBuildInfoFile": ".tsbuildinfo",

		"types": ["bun"]
	},
	"include": [
		"src/**/*",
		"test/**/*",
		"examples/**/*",
		"benchmarks/**/*",
		"types/**/*"
	],
	"exclude": ["vendor", "node_modules", "../../node_modules", "patches"]
}
