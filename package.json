{
	"name": "@aphrody-code/bxc",
	"version": "0.3.1",
	"description": "Bxc: High-performance browser automation & scraping engine (Bun + Rust/Zig + native Chromium)",
	"packageManager": "bun@1.3.14",
	"type": "module",
	"workspaces": [
		"packages/*",
		"vendor/mcp-sdk-typescript",
		"vendor/mcp-sdk-typescript/packages/*",
		"vendor/mcp-sdk-typescript/packages/middleware/*",
		"vendor/mcp-sdk-typescript/common/*",
		"vendor/mcp-sdk-typescript/test/*",
		"vendor/mcp-sdk-typescript/examples/*"
	],
	"main": "./src/api/browser.ts",
	"types": "./src/api/browser.ts",
	"bin": {
		"bxc": "./bin/bxc"
	},
	"files": [
		"src/",
		"bin/",
		"types/",
		"patches/",
		"LICENSE",
		"README.md"
	],
	"exports": {
		".": "./src/api/browser.ts",
		"./browser": "./src/api/browser.ts",
		"./detect": "./src/detect.ts",
		"./google": "./src/google/index.ts",
		"./mirror": "./src/mirror/index.ts",
		"./ffi/rust-bridge": "./src/rust/bridge.ts",
		"./ffi/curl-impersonate": "./src/ffi/curl-impersonate.ts",
		"./types/ConnectionTransport": "./types/ConnectionTransport.ts"
	},
	"scripts": {
		"build": "bun run build:linux && bun run build:win",
		"build:linux": "cd rust-bridge && cargo build --release && cd .. && bun scripts/build-standalone.ts",
		"build:win": "bun scripts/build-windows.ts",
		"build:win:aggressive": "bun scripts/build-windows.ts --baseline",
		"test": "bun test test/ src/",
		"test:google": "bun test test/google-power.test.ts",
		"test:rust": "bun test test/rust-bridge.test.ts",
		"lint": "oxlint src test scripts",
		"lint:fix": "oxlint --fix src test scripts",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"build:mcp": "bun build ./src/mcp/server.ts --compile --target=bun-windows-x64 --outfile ./dist/standalone/bxc-mcp",
		"clean": "bun scripts/cleanup.ts"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"peerDependencies": {
		"bun": "^1.3.14"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@biomejs/biome": "^2.4.15",
		"@playwright/test": "^1.60.0",
		"@types/babel__core": "^7.20.5",
		"@types/bun": "^1.3.14",
		"@types/jsdom": "^28.0.3",
		"babel-plugin-react-compiler": "^1.0.0",
		"cheerio": "^1.2.0",
		"jsdom": "^29.1.1",
		"openapi-typescript": "^7.13.0",
		"oxlint": "^1.65.0",
		"patchright": "^1.59.4",
		"playwright": "^1.60.0",
		"puppeteer-core": "^25.0.2",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"zod": "^4.4.3"
	}
}
