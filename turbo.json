{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*", "rust-bridge/src/**/*", "rust-bridge/Cargo.*", "package.json", "tsconfig.json"],
      "outputs": ["dist/**", "vendor/**/zig-out/**", "rust-bridge/target/release/libbxc_rust_bridge.*", "rust-bridge/target/release/bxc-engine"],
      "cache": true
    },
    "build:rust": {
      "inputs": ["rust-bridge/src/**/*", "rust-bridge/Cargo.*"],
      "outputs": ["rust-bridge/target/release/libbxc_rust_bridge.*", "rust-bridge/target/release/bxc-engine"]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**/*", "test/**/*", "package.json"],
      "outputs": []
    },
    "lint": {
      "inputs": ["src/**/*", "test/**/*", "examples/**/*", "scripts/**/*"],
      "outputs": []
    },
    "typecheck": {
      "inputs": ["src/**/*", "test/**/*", "examples/**/*", "tsconfig.json", "package.json"],
      "outputs": [".tsbuildinfo"]
    }
  }
}
